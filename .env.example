# FinPilot 环境变量样例（按 agent-rules / GLOBAL.md：.env 不入 git，.env.example 入 git）
# 用法：cp .env.example .env，再填入真实值

# === LLM 选择 + API Keys ===
# 默认 anthropic；可改为 openai / deepseek / ollama
LLM_PROVIDER=anthropic

# Anthropic Claude（v0.1 默认）
ANTHROPIC_API_KEY=sk-ant-xxx

# OpenAI（备用 / 可换 base_url 接 DeepSeek）
OPENAI_API_KEY=sk-xxx
# 用 DeepSeek 时取消下面这行注释 + 改 LLM_PROVIDER=openai
# OPENAI_BASE_URL=https://api.deepseek.com

# DeepSeek（独立 key，与 OPENAI_BASE_URL 二选一）
DEEPSEEK_API_KEY=sk-xxx

# Ollama 本地（可选 fallback；LLM_PROVIDER=ollama 时启用）
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# === 数据源（A 股 + 美股；v0.1 全免费档） ===
# AKShare：无 key
# SEC EDGAR：必须设 User-Agent（按 SEC 规则）
SEC_EDGAR_USER_AGENT="FinPilot v0.1 jeff.pang.liu@gmail.com"

# Finnhub（美股新闻情绪，可选）
FINNHUB_API_KEY=

# Tushare Pro（A 股财务交叉校验，可选；要去 tushare.pro 拿 token）
TUSHARE_TOKEN=

# === 运行时 ===
LOG_LEVEL=INFO
LOG_FILE=logs/fin-pilot.log

# === CORS（前端 dev 服务器地址；多个用逗号分隔） ===
CORS_ORIGINS=http://localhost:3000
